{
  "manifest_version": 3,
  "name": "YT Spotify Sync API",
  "version": "1.0",
  "permissions": ["tabs"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}